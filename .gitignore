# Keep this repository as a portable Codex + Obsidian research vault.
# Default deny: explicitly allow only guidance, the repo-local
# DeepPaperNote skill, Markdown notes, and legacy paper-note image assets.
*
!*/

!.gitignore
!.gitattributes
!AGENTS.md
!README.md
!更新报告.md

# Repo-local skills.
!.agents/
!.agents/skills/
!.agents/skills/DeepPaperNote/
!.agents/skills/DeepPaperNote/**
!.agents/skills/zotero-pdf-sync/
!.agents/skills/zotero-pdf-sync/**

# Keep in-skill development output out of the vault.
.agents/skills/**/site/.astro/
.agents/skills/**/.agent-work/
.agents/skills/**/.venv/
.agents/skills/**/venv/
.agents/skills/**/dist/
.agents/skills/**/build/
*.egg-info/

# Obsidian outputs mirror the Zotero collection hierarchy under 文献/; images are legacy reader assets.
!文献/
!文献/论文导航.md
!文献/论文库.base
!文献/**/
!文献/**/笔记.md
!文献/**/images/
!文献/**/images/*.png
!文献/**/images/*.jpg
!文献/**/images/*.jpeg
!文献/**/images/*.webp
!文献/**/images/*.gif
!文献/**/images/*.svg

# Terminal archive from a full Zotero mirror is deliberately local-only.
文献/Zotero已删除/

# Local machine state and private data, including the Zotero mirror index and reports.
.local/
.env
.env.*
*.key
*.pem
*.pfx
*.crt

# Zotero databases, attachments, and full-text caches stay local.
*.sqlite
*.sqlite-*
*.db
*.pdf
*.epub
*.zotero-ft-cache
storage/

# Obsidian UI/cache state is intentionally not synced.
.obsidian/
.trash/

# Temporary outputs and caches.
DeepPaperNote_output/
tmp/
*.tmp
*.temp
*.bak
*.log
__pycache__/
*.py[cod]
node_modules/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Tracked Vault and CI assets.
!.github/
!.github/workflows/
!.github/workflows/deeppapernote-v2.yml
