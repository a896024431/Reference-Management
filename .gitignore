# Keep this repository as a portable Codex + Obsidian research vault.
# Default deny: explicitly allow only guidance, the repo-local
# DeepPaperNote skill, Markdown notes, and paper-note image assets.
*
!*/

!.gitignore
!.gitattributes
!AGENTS.md
!README.md
!更新报告.md

# Repo-local DeepPaperNote skill.
!.agents/
!.agents/skills/
!.agents/skills/DeepPaperNote/
!.agents/skills/DeepPaperNote/**

# Keep skill-specific output not covered by the global rules below out of the vault.
.agents/skills/DeepPaperNote/site/.astro/
.agents/skills/DeepPaperNote/.agent-work/
.agents/skills/DeepPaperNote/.venv/
.agents/skills/DeepPaperNote/venv/
.agents/skills/DeepPaperNote/dist/
.agents/skills/DeepPaperNote/build/
*.egg-info/

# DeepPaperNote Obsidian outputs.
!Research/
!Research/论文导航.md
!Research/论文库.base
!Research/*/
!Research/*/笔记.md
!Research/*/images/
!Research/*/images/*.png
!Research/*/images/*.jpg
!Research/*/images/*.jpeg
!Research/*/images/*.webp
!Research/*/images/*.gif
!Research/*/images/*.svg

# Local machine state and private data.
.local/
.env
.env.*
*.key
*.pem
*.pfx
*.crt

# Zotero databases, attachments, and full-text caches stay local.
*.sqlite
*.sqlite-*
*.db
*.pdf
*.epub
*.zotero-ft-cache
storage/

# Obsidian UI/cache state is intentionally not synced.
.obsidian/
.trash/

# Temporary outputs and caches.
DeepPaperNote_output/
tmp/
*.tmp
*.temp
*.bak
*.log
__pycache__/
*.py[cod]
node_modules/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Tracked Vault and CI assets.
!.github/
!.github/workflows/
!.github/workflows/deeppapernote-v2.yml
